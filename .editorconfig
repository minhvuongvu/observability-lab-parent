# Editor defaults for the repository. Keeps formatting stable across IDEs so
# diffs stay meaningful. See https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.java]
indent_size = 4
max_line_length = 120

[*.{xml,xsd}]
indent_size = 4

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[*.md]
indent_size = 2
# Two trailing spaces are a hard line break in Markdown.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
