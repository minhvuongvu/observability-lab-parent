{
  "realm": "observability",
  "displayName": "Observability Lab",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,

  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "revokeRefreshToken": false,

  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Standard authenticated user. May read and place orders and read stock."
      },
      {
        "name": "ADMIN",
        "description": "Elevated user. May additionally perform destructive operations (DELETE)."
      }
    ]
  },

  "clients": [
    {
      "clientId": "gateway",
      "name": "API Gateway (Kong / BFF)",
      "description": "Confidential client representing the edge. Demonstrates client-credentials and the confidential authorization-code flow.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "gateway-local-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": ["http://localhost/*", "http://localhost:8000/*"],
      "webOrigins": ["+"],
      "fullScopeAllowed": true
    },
    {
      "clientId": "swagger-ui",
      "name": "Swagger UI",
      "description": "Public client the per-service Swagger UIs authenticate through. Direct access grants are enabled so the documented curl token flow works without a secret.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:8081/*",
        "http://localhost:8082/*",
        "http://localhost/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "fullScopeAllowed": true
    },
    {
      "clientId": "frontend",
      "name": "Frontend (placeholder SPA)",
      "description": "Public single-page-application placeholder. Standard authorization-code flow with PKCE; no direct access grants.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "fullScopeAllowed": true
    }
  ],

  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "User",
      "email": "alice@lab.local",
      "credentials": [
        { "type": "password", "value": "alice", "temporary": false }
      ],
      "realmRoles": ["USER"]
    },
    {
      "username": "manager",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Mona",
      "lastName": "Manager",
      "email": "manager@lab.local",
      "credentials": [
        { "type": "password", "value": "manager", "temporary": false }
      ],
      "realmRoles": ["ADMIN", "USER"]
    }
  ],

  "components": {
    "org.keycloak.keys.KeyProvider": [
      {
        "name": "rsa-lab-fixed",
        "providerId": "rsa",
        "subComponents": {},
        "config": {
          "priority": ["101"],
          "enabled": ["true"],
          "active": ["true"],
          "algorithm": ["RS256"],
          "privateKey": [""],
          "certificate": [""]
        }
      },
      {
        "name": "hmac-generated",
        "providerId": "hmac-generated",
        "config": {
          "priority": ["100"],
          "enabled": ["true"],
          "active": ["true"],
          "algorithm": ["HS512"]
        }
      },
      {
        "name": "aes-generated",
        "providerId": "aes-generated",
        "config": {
          "priority": ["100"],
          "enabled": ["true"],
          "active": ["true"]
        }
      }
    ]
  }
}
