{
  "uid": "lab-service-runtime",
  "title": "Runtime — JVM, HTTP, Pool, Kafka, Redis",
  "description": "The technical health of both services: request rate and latency, JVM memory and GC, database pool saturation, Kafka client throughput and Redis command latency. Everything here is instrumentation Micrometer registers automatically; the business view is on the Business dashboard. See docs/Metrics.md.",
  "tags": ["observability-lab", "metrics", "runtime"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Store",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": { "query": "label_values(jvm_memory_used_bytes, service)", "refId": "service" },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "HTTP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "id": 1,
      "title": "Request rate by service",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(http_server_requests_seconds_count{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "id": 2,
      "title": "Request latency",
      "description": "p50, p95 and p99 from bucket counts. On its own axis rather than sharing one with the rate panel: requests-per-second and seconds are different units, and putting both on one y-axis makes neither readable.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{service=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{service=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{service=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "id": 3,
      "title": "Responses by outcome",
      "description": "Status class rather than raw code: SUCCESS, CLIENT_ERROR and SERVER_ERROR are what a decision is made on, and the exact code is a log question.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(http_server_requests_seconds_count{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{outcome}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "pointSize": 8, "stacking": { "mode": "normal" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "SUCCESS" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "CLIENT_ERROR" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "SERVER_ERROR" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "type": "row",
      "id": 101,
      "title": "JVM",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "type": "timeseries",
      "id": 4,
      "title": "Heap used",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (jvm_memory_used_bytes{service=~\"$service\", area=\"heap\"})",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "GC pause rate",
      "description": "Time spent paused per second. More useful than a pause count: ten 1ms pauses and one 500ms pause are very different experiences for a caller.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(jvm_gc_pause_seconds_sum{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Live threads",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (jvm_threads_live_threads{service=~\"$service\"})",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "CPU usage",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "expr": "process_cpu_usage{service=~\"$service\"}",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "id": 102,
      "title": "Database pool, Kafka, Redis",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Connection pool",
      "description": "Active against pending. Threads pending on a connection is the shape almost every 'the site is slow' incident actually has.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (hikaricp_connections_active{service=~\"$service\"})",
          "legendFormat": "{{service}} active"
        },
        {
          "refId": "B",
          "expr": "sum by (service) (hikaricp_connections_pending{service=~\"$service\"})",
          "legendFormat": "{{service}} pending"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Kafka client throughput",
      "description": "Records produced and consumed per second, straight from the Kafka client's own metrics.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(kafka_producer_record_send_total{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service}} produced"
        },
        {
          "refId": "B",
          "expr": "sum by (service) (rate(kafka_consumer_fetch_manager_records_consumed_total{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service}} consumed"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Redis command latency",
      "description": "From the Lettuce client. A cache that has become slower than the database it fronts is worse than no cache.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(lettuce_command_completion_seconds_sum{service=~\"$service\"}[$__rate_interval])) / sum by (service) (rate(lettuce_command_completion_seconds_count{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": []
      }
    }
  ]
}
