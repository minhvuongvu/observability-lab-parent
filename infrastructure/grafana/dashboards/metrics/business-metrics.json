{
  "uid": "lab-business-metrics",
  "title": "Business — Order Flow",
  "description": "The metrics that describe whether the business is working, as opposed to whether the processes are healthy. A deployment can be green on every JVM and HTTP panel while orders stop settling; this dashboard is where that shows up. See docs/Metrics.md.",
  "tags": ["observability-lab", "metrics", "business"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Store",
        "description": "Prometheus holds 24h and evaluates the alerts; VictoriaMetrics holds the same samples for 30d. Both answer PromQL, so any panel can be compared across the two.",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Orders accepted",
      "description": "Total in range.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(lab_orders_accepted_total[$__range]))", "instant": true }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value", "colorMode": "none", "graphMode": "area", "justifyMode": "center"
      },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Settled",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(lab_orders_settled_total[$__range]))", "instant": true }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value", "colorMode": "none", "graphMode": "area", "justifyMode": "center"
      },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Unsettled",
      "description": "Accepted minus settled. The single most important number here: a persistent gap means orders are being taken and never answered, which no technical metric reports.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "sum(increase(lab_orders_accepted_total[$__range])) - sum(increase(lab_orders_settled_total[$__range]))"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value", "colorMode": "value", "graphMode": "none", "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Outbox backlog",
      "description": "Events written but not yet acknowledged by Kafka. Should sit at zero; a sustained non-zero value means the relay cannot reach the broker.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [{ "refId": "A", "expr": "sum(lab_outbox_pending_events)", "instant": true }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value", "colorMode": "value", "graphMode": "area", "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Accepted vs settled",
      "description": "The two rates on one axis because they measure the same thing in the same unit — orders per second — and the whole point is whether the lines track each other. Divergence is the signal.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(lab_orders_accepted_total[$__rate_interval]))", "legendFormat": "accepted" },
        { "refId": "B", "expr": "sum(rate(lab_orders_settled_total[$__rate_interval]))", "legendFormat": "settled" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Settlement outcome",
      "description": "Confirmed against rejected. A rising rejection rate is the earliest sign that the catalogue and the warehouse disagree — and it is never an error, so it appears in no error metric.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(lab_orders_settled_total[$__rate_interval]))",
          "legendFormat": "{{outcome}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "confirmed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "rejected" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      }
    },
    {
      "type": "row",
      "id": 101,
      "title": "Latency and value",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "Reservation latency",
      "description": "Percentiles computed from histogram buckets, which is the only form that aggregates correctly when the service is scaled out.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(lab_reservation_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(lab_reservation_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(lab_reservation_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Order value distribution",
      "description": "Median against p95 basket value. An average would hide both: one large order moves a mean and leaves the median where it was.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(lab_order_value_currency_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(lab_order_value_currency_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never", "pointSize": 8 }
        },
        "overrides": []
      }
    }
  ]
}
