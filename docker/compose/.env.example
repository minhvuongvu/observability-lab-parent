# ===========================================================================
# Observability Lab - environment template
#
#   cp .env.example .env       (../../scripts/infra.sh does this for you)
#
# .env is git-ignored. This template is tracked, so it documents every
# variable the stack needs and must never contain a real credential.
#
# The passwords below are deliberately obvious local-only placeholders. They
# exist so `infra.sh up` works on a fresh clone without editing anything.
# They are safe only because every port binds to 127.0.0.1. Change them
# before exposing anything, and never reuse them anywhere else.
# ===========================================================================

# --- Compose wiring --------------------------------------------------------
COMPOSE_PROJECT_NAME=observability-lab
# All three files are always used together: Keycloak needs the PostgreSQL
# service declared in the core file, and the observability file's heavier
# components are gated behind the `search` profile rather than by being left
# out of this list.
COMPOSE_FILE=docker-compose.yml:docker-compose.platform.yml:docker-compose.observability.yml
# Pinned, because Compose splits COMPOSE_FILE on this and its default is ':' on
# macOS and Linux but ';' on Windows. Left to the default, the line above
# becomes a single nonexistent filename on Windows and nothing starts.
# ./scripts/infra.sh passes -f explicitly and does not depend on either.
COMPOSE_PATH_SEPARATOR=:

# Interface every published port binds to. 127.0.0.1 keeps the whole stack
# off the local network. Set to 0.0.0.0 only if you know why you need it.
BIND_HOST=127.0.0.1

# --- Image pins ------------------------------------------------------------
# Pinned rather than :latest so a rebuild months from now behaves identically.
POSTGRES_IMAGE=postgres:17-alpine
# Oracle Database Free 23ai is the current name of Oracle XE and, unlike the
# 21c XE images, ships a native arm64 build. On Apple Silicon the 21c images
# only run under emulation. To use 21c XE instead:
#   ORACLE_IMAGE=gvenzl/oracle-xe:21-slim-faststart
ORACLE_IMAGE=gvenzl/oracle-free:23-slim-faststart
KAFKA_IMAGE=apache/kafka:4.2.1
KAFKA_UI_IMAGE=kafbat/kafka-ui:v1.5.0
REDIS_IMAGE=redis:7.4-alpine
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z
CONSUL_IMAGE=hashicorp/consul:1.22.7
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.7.0
KONG_IMAGE=kong:3.9.3
NGINX_IMAGE=nginx:1.30-alpine

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_PORT=5432
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=localdev_postgres_superuser
POSTGRES_SUPERUSER_DB=postgres

# Order Service database, created by infrastructure/postgres/init.
ORDER_DB_NAME=orderdb
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=localdev_order_pw

# Keycloak's own database in the same engine, with a separate owning role.
KEYCLOAK_DB_NAME=keycloakdb
KEYCLOAK_DB_USER=keycloak_user
KEYCLOAK_DB_PASSWORD=localdev_keycloak_db_pw

# --- Oracle ----------------------------------------------------------------
ORACLE_PORT=1521
# Password for SYS and SYSTEM. Alphanumeric on purpose: Oracle connect strings
# and JDBC URLs both mangle several punctuation characters.
ORACLE_SYS_PASSWORD=LocalDevOracleSys1
ORACLE_PDB=FREEPDB1
INVENTORY_DB_USER=inventory_user
INVENTORY_DB_PASSWORD=LocalDevInventory1

# --- Kafka -----------------------------------------------------------------
# Host-facing listener. Containers use kafka:9092 on the internal network;
# anything on the host - a service run from the IDE - uses this port.
KAFKA_EXTERNAL_PORT=29092
# KRaft cluster identity. Fixed so the log directory survives a recreate.
# Regenerate for a fresh cluster:
#   python3 -c "import base64,uuid;print(base64.urlsafe_b64encode(uuid.uuid4().bytes).decode().rstrip('='))"
KAFKA_CLUSTER_ID=OJW-IFSTRF-Qo383JXvduQ
# Single broker, so replication cannot exceed 1.
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION=1
KAFKA_UI_PORT=8090

# --- Redis -----------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=localdev_redis_pw

# --- MinIO -----------------------------------------------------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=lab-minio-root
MINIO_ROOT_PASSWORD=localdev_minio_root_pw
# Least-privilege account the services actually use. Scoped to the invoice
# bucket by infrastructure/minio/init.
MINIO_APP_USER=lab-invoice-app
MINIO_APP_PASSWORD=localdev_minio_app_pw
MINIO_INVOICE_BUCKET=invoices

# --- Consul ----------------------------------------------------------------
CONSUL_PORT=8500

# --- Keycloak --------------------------------------------------------------
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=localdev_keycloak_admin_pw
# Realm imported on boot from infrastructure/keycloak/realm (step 07).
KEYCLOAK_REALM=observability
# Token issuer. Every token is minted through this URL, so its `iss` claim is
# exactly this string - which is what both Kong (static key, keyed by iss) and
# the services (issuer validation) check against. If KEYCLOAK_PORT changes, this
# and the Kong consumer key in infrastructure/kong/kong.yml must change with it.
KEYCLOAK_ISSUER=http://localhost:${KEYCLOAK_PORT}/realms/${KEYCLOAK_REALM}
# JWKS endpoint the services fetch verification keys from. Reachable from the
# host because the Keycloak port is published there.
KEYCLOAK_JWKS_URI=${KEYCLOAK_ISSUER}/protocol/openid-connect/certs
# Lab sign-in credentials, seeded by the realm import (local development only):
#   alice / alice     -> realm role USER
#   manager / manager -> realm roles ADMIN, USER
# Public client used for the documented password-grant token flow.
KEYCLOAK_CLIENT_ID=swagger-ui

# --- Kong ------------------------------------------------------------------
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001
KONG_MANAGER_PORT=8002

# --- Nginx -----------------------------------------------------------------
NGINX_HTTP_PORT=80

# --- Observability: logging (step 10) --------------------------------------
# Loki and its two agents plus Grafana start with a normal `up`.
# OpenSearch, OpenSearch Dashboards, Elasticsearch, Kibana and Fluentd are
# gated behind the `search` compose profile, because they need roughly 4 GB
# that a machine already running Oracle and Kafka does not have spare:
#
#     docker compose --profile search up -d
#
LOKI_IMAGE=grafana/loki:3.5.7
PROMTAIL_IMAGE=grafana/promtail:3.5.7
FLUENT_BIT_IMAGE=fluent/fluent-bit:4.2.7
# Base image for docker/fluentd/Dockerfile, which adds the OpenSearch plugin.
FLUENTD_VERSION=v1.19-debian-1
OPENSEARCH_IMAGE=opensearchproject/opensearch:2.19.6
OPENSEARCH_DASHBOARDS_IMAGE=opensearchproject/opensearch-dashboards:2.19.6
ELASTICSEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.19.7
KIBANA_IMAGE=docker.elastic.co/kibana/kibana:8.19.7
GRAFANA_IMAGE=grafana/grafana:12.2.10

LOKI_PORT=3100
GRAFANA_PORT=3000
# OpenSearch and Elasticsearch both listen on 9200 inside their containers, so
# they are published on different host ports. Same for their two dashboards.
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601
ELASTICSEARCH_PORT=9201
KIBANA_PORT=5602

# Grafana allows anonymous viewing; these credentials are needed only to edit.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=localdev_grafana_admin_pw

# --- Observability: metrics (step 11) --------------------------------------
# Prometheus scrapes; VictoriaMetrics receives a remote_write copy of every
# sample and answers the same PromQL, so both can be compared from Grafana.
PROMETHEUS_IMAGE=prom/prometheus:v3.7.3
VICTORIAMETRICS_IMAGE=victoriametrics/victoria-metrics:v1.111.0
PROMETHEUS_PORT=9090
VICTORIAMETRICS_PORT=8428

# --- Observability: tracing (step 12) --------------------------------------
# Services export OTLP to the collector only; it fans out to all three stores.
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.140.1
TEMPO_IMAGE=grafana/tempo:2.9.1
JAEGER_IMAGE=jaegertracing/all-in-one:1.66.0
ZIPKIN_IMAGE=openzipkin/zipkin:3.6.1

OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
OTEL_ZPAGES_PORT=55679
TEMPO_PORT=3200
JAEGER_UI_PORT=16686
ZIPKIN_PORT=9411

# --- Observability: profiling (step 13) ------------------------------------
# Continuous CPU, allocation and lock profiling. The agent is attached by
# run-service.sh; set PYROSCOPE_ENABLED=false there to run without it.
PYROSCOPE_IMAGE=grafana/pyroscope:1.16.0
PYROSCOPE_PORT=4040

# --- Observability: alerting (step 16) -------------------------------------
# Alertmanager routes what Prometheus evaluates. Until step 16 the rules fired
# and nothing was notified; these are the components that close that gap, plus
# the exporters four of the required alerts have no series to fire on without.
ALERTMANAGER_IMAGE=prom/alertmanager:v0.28.1
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.9.1
POSTGRES_EXPORTER_IMAGE=prometheuscommunity/postgres-exporter:v0.17.1
ORACLE_EXPORTER_IMAGE=ghcr.io/iamseth/oracledb_exporter:0.6.0
REDIS_EXPORTER_IMAGE=oliver006/redis_exporter:v1.69.0
KAFKA_EXPORTER_IMAGE=danielqsj/kafka-exporter:v1.9.0
# Delivery sinks. Both exist so an alert can be *seen* arriving rather than
# assumed: Mailpit captures SMTP and shows it in a browser, and the echo
# container logs every webhook body it receives.
MAILPIT_IMAGE=axllent/mailpit:v1.22
WEBHOOK_SINK_IMAGE=mendhak/http-https-echo:37

ALERTMANAGER_PORT=9093
NODE_EXPORTER_PORT=9100
POSTGRES_EXPORTER_PORT=9187
ORACLE_EXPORTER_PORT=9161
REDIS_EXPORTER_PORT=9121
KAFKA_EXPORTER_PORT=9308
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
ALERT_WEBHOOK_PORT=8099

# Read-only monitoring credentials. Separate from the application accounts on
# purpose: an exporter is a process with a database password that is scraped
# over plain HTTP, so it gets the narrowest role that answers the question.
#
# Created by the datastore init scripts, which run ONLY on first initialisation
# of an empty volume. An existing stack needs ./scripts/infra.sh destroy, or the
# users created by hand - see docs/Alerting.md.
MONITOR_DB_USER=lab_monitor
MONITOR_DB_PASSWORD=localdev_monitor_pw
ORACLE_MONITOR_USER=LAB_MONITOR
ORACLE_MONITOR_PASSWORD=LocalDevMonitor1

# Alert recipients and the webhook URL are deliberately NOT here. Alertmanager
# does not expand environment variables in its configuration file, so a value
# set here would be silently ignored while looking configured - the worst of
# both. They live in infrastructure/alertmanager/alertmanager.yml, which is
# also where a reviewer would look for them. Grafana's copies are in
# infrastructure/grafana/provisioning/alerting/contact-points.yml.
