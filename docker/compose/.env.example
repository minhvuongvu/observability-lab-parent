# ===========================================================================
# Observability Lab - environment template
#
#   cp .env.example .env       (../../scripts/infra.sh does this for you)
#
# .env is git-ignored. This template is tracked, so it documents every
# variable the stack needs and must never contain a real credential.
#
# The passwords below are deliberately obvious local-only placeholders. They
# exist so `infra.sh up` works on a fresh clone without editing anything.
# They are safe only because every port binds to 127.0.0.1. Change them
# before exposing anything, and never reuse them anywhere else.
# ===========================================================================

# --- Compose wiring --------------------------------------------------------
COMPOSE_PROJECT_NAME=observability-lab
# Both files are always used together: Keycloak needs the PostgreSQL service
# declared in the core file.
COMPOSE_FILE=docker-compose.yml:docker-compose.platform.yml

# Interface every published port binds to. 127.0.0.1 keeps the whole stack
# off the local network. Set to 0.0.0.0 only if you know why you need it.
BIND_HOST=127.0.0.1

# --- Image pins ------------------------------------------------------------
# Pinned rather than :latest so a rebuild months from now behaves identically.
POSTGRES_IMAGE=postgres:17-alpine
# Oracle Database Free 23ai is the current name of Oracle XE and, unlike the
# 21c XE images, ships a native arm64 build. On Apple Silicon the 21c images
# only run under emulation. To use 21c XE instead:
#   ORACLE_IMAGE=gvenzl/oracle-xe:21-slim-faststart
ORACLE_IMAGE=gvenzl/oracle-free:23-slim-faststart
KAFKA_IMAGE=apache/kafka:4.2.1
KAFKA_UI_IMAGE=kafbat/kafka-ui:v1.5.0
REDIS_IMAGE=redis:7.4-alpine
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z
CONSUL_IMAGE=hashicorp/consul:1.22.7
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.7.0
KONG_IMAGE=kong:3.9.3
NGINX_IMAGE=nginx:1.30-alpine

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_PORT=5432
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=localdev_postgres_superuser
POSTGRES_SUPERUSER_DB=postgres

# Order Service database, created by infrastructure/postgres/init.
ORDER_DB_NAME=orderdb
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=localdev_order_pw

# Keycloak's own database in the same engine, with a separate owning role.
KEYCLOAK_DB_NAME=keycloakdb
KEYCLOAK_DB_USER=keycloak_user
KEYCLOAK_DB_PASSWORD=localdev_keycloak_db_pw

# --- Oracle ----------------------------------------------------------------
ORACLE_PORT=1521
# Password for SYS and SYSTEM. Alphanumeric on purpose: Oracle connect strings
# and JDBC URLs both mangle several punctuation characters.
ORACLE_SYS_PASSWORD=LocalDevOracleSys1
ORACLE_PDB=FREEPDB1
INVENTORY_DB_USER=inventory_user
INVENTORY_DB_PASSWORD=LocalDevInventory1

# --- Kafka -----------------------------------------------------------------
# Host-facing listener. Containers use kafka:9092 on the internal network;
# anything on the host - a service run from the IDE - uses this port.
KAFKA_EXTERNAL_PORT=29092
# KRaft cluster identity. Fixed so the log directory survives a recreate.
# Regenerate for a fresh cluster:
#   python3 -c "import base64,uuid;print(base64.urlsafe_b64encode(uuid.uuid4().bytes).decode().rstrip('='))"
KAFKA_CLUSTER_ID=OJW-IFSTRF-Qo383JXvduQ
# Single broker, so replication cannot exceed 1.
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION=1
KAFKA_UI_PORT=8090

# --- Redis -----------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=localdev_redis_pw

# --- MinIO -----------------------------------------------------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=lab-minio-root
MINIO_ROOT_PASSWORD=localdev_minio_root_pw
# Least-privilege account the services actually use. Scoped to the invoice
# bucket by infrastructure/minio/init.
MINIO_APP_USER=lab-invoice-app
MINIO_APP_PASSWORD=localdev_minio_app_pw
MINIO_INVOICE_BUCKET=invoices

# --- Consul ----------------------------------------------------------------
CONSUL_PORT=8500

# --- Keycloak --------------------------------------------------------------
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=localdev_keycloak_admin_pw

# --- Kong ------------------------------------------------------------------
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001
KONG_MANAGER_PORT=8002

# --- Nginx -----------------------------------------------------------------
NGINX_HTTP_PORT=80
