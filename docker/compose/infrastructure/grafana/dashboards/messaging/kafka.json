{
  "uid": "lab-kafka",
  "title": "Kafka \u2014 Producers, Consumers, Lag",
  "description": "The event backbone as the clients see it. Consumer lag is the single most important number: it is the only one that says whether the asynchronous half of the order flow is keeping up. See docs/Kafka.md.",
  "tags": [
    "observability-lab",
    "kafka",
    "messaging"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Store",
        "description": "Prometheus holds 24h and evaluates the alerts; VictoriaMetrics holds the same samples for 30d. Both answer PromQL.",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "prometheus"
        }
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(up, service)",
          "refId": "service"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Is it keeping up?",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Max consumer lag",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(kafka_consumer_fetch_manager_records_lag_max{service=~\"$service\"})",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 100
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "Records behind the head of the partition. Sustained growth means consumption is slower than production, and every order in that backlog is one whose stock is not yet reserved."
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Produced/s",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kafka_producer_record_send_total{service=~\"$service\"}[$__rate_interval]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Consumed/s",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kafka_consumer_fetch_manager_records_consumed_total{service=~\"$service\"}[$__rate_interval]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "id": 101,
      "title": "Throughput and lag",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 4,
      "title": "Lag by topic and partition",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (topic, partition) (kafka_consumer_fetch_manager_records_lag{service=~\"$service\"})",
          "legendFormat": "{{topic}}[{{partition}}]"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false
          },
          "min": 0
        },
        "overrides": []
      },
      "description": "Per partition, not summed. Lag concentrated on one partition means an uneven key distribution or one stuck consumer \u2014 a sum hides both."
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Produce vs consume",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(kafka_producer_record_send_total{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service}} produced"
        },
        {
          "refId": "B",
          "expr": "sum by (service) (rate(kafka_consumer_fetch_manager_records_consumed_total{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service}} consumed"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false
          },
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "id": 102,
      "title": "Client health",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Producer request latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 15
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (kafka_producer_request_latency_avg{service=~\"$service\"})",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false
          },
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "Rebalances",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 15
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(kafka_consumer_coordinator_rebalance_total{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false
          },
          "min": 0
        },
        "overrides": []
      },
      "description": "A rebalance stops consumption on every partition in the group while it happens. Frequent rebalances usually mean max.poll.interval.ms is too short for how long a record takes to handle."
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Producer errors",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 15
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(kafka_producer_record_error_total{service=~\"$service\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false
          },
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "row",
      "id": 103,
      "title": "Outbox and dead letters",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Outbox backlog",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (lab_outbox_pending_events)",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false
          },
          "min": 0
        },
        "overrides": []
      },
      "description": "Events owed to Kafka. The outbox makes delivery retryable; a backlog that does not drain means the relay cannot reach the broker at all."
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Dead-lettered messages",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service, reason) (rate(lab_messages_dead_lettered_total[$__rate_interval])) or vector(0)",
          "legendFormat": "{{service}} {{reason}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false
          },
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "description": "Any dead letter is worth a look: by definition it exhausted its retries, so nothing will pick it up automatically."
    }
  ]
}
